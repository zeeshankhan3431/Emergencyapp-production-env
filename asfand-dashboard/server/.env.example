PORT=3001
# Auth bypass for local UI (matches authenticateJWT dev user)
SKIP_AUTH=true

# PostgreSQL — leave unset to use in-memory DB (pg-mem) for local dev only
# DATABASE_URL=postgresql://user:pass@localhost:5432/emergencydb

# When using real AWS (optional for local in-memory mode)
# AWS_REGION=us-east-1
# AUDIT_LOG_DISABLED=true
