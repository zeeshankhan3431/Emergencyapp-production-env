PORT=3001

# ── Local dev (in-memory DB) ─────────────────────────────────────────────────
# Leave DATABASE_URL unset to use pg-mem. Set SKIP_AUTH=true to bypass JWT in API calls.
SKIP_AUTH=true
COGNITO_USE_MOCK=true
MOCK_AUTO_VERIFY=true
REGISTRATION_ROLE_SECRET=era-dev-admin-secret
JWT_SECRET=local-dev-jwt-secret-change-in-production
AUTO_CONFIRM_SIGNUP=true

# ── AWS (run scripts/configure-aws-env.sh to auto-fill from deployed stacks) ─
# AWS_REGION=us-east-1
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_USE_MOCK=false
# SKIP_AUTH=false

# ── PostgreSQL (RDS in VPC — used when API runs in ECS or with VPN/bastion) ───
# DATABASE_URL=postgresql://era_admin:PASSWORD@RDS_HOST:5432/emergencydb
# Or set RDS_HOST + RDS_PASSWORD (ECS injects these from Secrets Manager)
# RUN_MIGRATIONS=true

# ── AWS services (optional for local in-memory mode) ─────────────────────────
# KINESIS_STREAM_NAME=incident-events-dev
# S3_EVIDENCE_BUCKET=
# TRANSCRIPTION_QUEUE_URL=
# SUMMARISATION_QUEUE_URL=
