{
  "name": "era-infra",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node ./node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "synth": "npm run build && node ./node_modules/aws-cdk/bin/cdk synth",
    "deploy": "npm run build && node ./node_modules/aws-cdk/bin/cdk deploy --all --require-approval never",
    "diff": "npm run build && node ./node_modules/aws-cdk/bin/cdk diff",
    "bootstrap": "node ./node_modules/aws-cdk/bin/cdk bootstrap --verbose",
    "fix-bin-perms": "chmod +x node_modules/.bin/* node_modules/typescript/bin/* 2>/dev/null || true"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.187.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "aws-cdk": "^2.187.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "@types/node": "^22.14.0"
  }
}
